{
    "name": "sprintly",
    "private": true,
    "scripts": {
        "format": "prettier --write .",
        "lint:fix": "eslint . --cache --fix",
        "dev": "pnpm -r --parallel dev",
        "dev:api": "pnpm --filter @apps/api dev",
        "dev:web": "pnpm --filter @apps/web dev"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.2",
        "eslint": "^9.39.2",
        "eslint-config-prettier": "^10.1.8",
        "prettier": "^3.8.0",
        "typescript-eslint": "^8.53.1"
    }
}
